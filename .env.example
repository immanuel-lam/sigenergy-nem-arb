# Home Assistant
HA_URL=http://ha.local:8123
HA_TOKEN=your-long-lived-access-token-here

# HA sensor entity IDs (confirm these)
HA_SENSOR_LOAD=sensor.grid_power
HA_SENSOR_SOLAR=sensor.solar_power
HA_SENSOR_SOC=sensor.battery_soc
HA_SENSOR_BATTERY_POWER=sensor.battery_power

# Sigenergy Modbus (direct — fallback only, HA integration holds the connection)
SIGEN_INVERTER_1_IP=192.168.1.100
SIGEN_INVERTER_2_IP=192.168.1.101
SIGEN_MODBUS_PORT=502
SIGEN_UNIT_ID_1=1
SIGEN_UNIT_ID_2=2

# Sigenergy control via HA (primary actuator path)
# These are entities created by the Sigenergy-Local-Modbus HA integration
HA_ENTITY_EMS_MODE=select.plant_remote_ems_control_mode
HA_ENTITY_MAX_CHARGE=number.plant_ess_max_charging_limit
HA_ENTITY_MAX_DISCHARGE=number.plant_ess_max_discharging_limit
HA_ENTITY_CHARGE_CUTOFF_SOC=number.plant_charge_cut_off_soc
HA_ENTITY_DISCHARGE_CUTOFF_SOC=number.plant_discharge_cut_off_soc

# Amber Electric (optional, falls back to AEMO NEMWEB)
AMBER_API_KEY=

# Location (for open-meteo solar forecast)
LATITUDE=-33.8688
LONGITUDE=151.2093

# Safety
DRY_RUN=true
ARB_KILL=0

# Anthropic (for explain.py rationale generation)
ANTHROPIC_API_KEY=your-api-key-here
