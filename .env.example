# Home Assistant
HA_URL=http://ha.local:8123
HA_TOKEN=your-long-lived-access-token-here

# HA sensor entity IDs (confirm these)
HA_SENSOR_LOAD=sensor.grid_power
HA_SENSOR_SOLAR=sensor.solar_power
HA_SENSOR_SOC=sensor.battery_soc
HA_SENSOR_BATTERY_POWER=sensor.battery_power

# Sigenergy Modbus
SIGEN_INVERTER_1_IP=192.168.1.100
SIGEN_INVERTER_2_IP=192.168.1.101
SIGEN_MODBUS_PORT=502
SIGEN_UNIT_ID_1=1
SIGEN_UNIT_ID_2=2

# Amber Electric (optional, falls back to AEMO NEMWEB)
AMBER_API_KEY=

# Location (for open-meteo solar forecast)
LATITUDE=-33.8688
LONGITUDE=151.2093

# Safety
DRY_RUN=true
ARB_KILL=0

# Anthropic (for explain.py rationale generation)
ANTHROPIC_API_KEY=your-api-key-here
